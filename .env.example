# ─────────────────────────────────────────────────────────────
# ChaiGPT Build — Environment Variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Database (Postgres) ──────────────────────────────────────
# Any Postgres works: Neon (https://neon.tech), Supabase, or local.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# ── Clerk Authentication ─────────────────────────────────────
# Get keys from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Route Clerk to the in-app sign-in page
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/

# ── OpenAI (chat model provider) ─────────────────────────────
# Get a key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Firecrawl (web search tool — Phase 1) ────────────────────
# Get your key from: https://www.firecrawl.dev → dashboard → API Keys
FIRECRAWL_API_KEY=
